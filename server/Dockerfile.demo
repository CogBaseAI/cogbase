FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml ./
RUN mkdir -p cogbase && touch cogbase/__init__.py
RUN pip install --no-cache-dir ".[demo]"

COPY . .

EXPOSE 8000

ENV COGBASE_CONFIG=/app/server/cogbase_system.demo.yaml

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
